# Server-side: used by scripts/fetch-data.mjs for Google Places enrichment
# (rating + reviewCount baked into public/data/points.geojson). Optional —
# enrichment is skipped cleanly when absent.
GOOGLE_PLACES_API_KEY=

# Client-side: street-level photo fallback in LocationCard when no Wikipedia
# image is found. Optional — Mapillary fallback is skipped when absent.
NEXT_PUBLIC_MAPILLARY_TOKEN=
